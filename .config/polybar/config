; vim:ft=dosini

[colors]
brightblack = #928374
brightred = #fb4934
brightgreen = #b8bb26
brightyellow = #fabd2f
brightblue = #83a598
brightmagenta = #d3869b
brightcyan = #8ec07c
brightwhite = #ebdbb2

black = #282828
red = #cc241d
green = #98971a
yellow = #d79921
blue = #458588
magenta = #b16286
cyan = #689d6a
white = #a89984

background = #282828
foreground = #ebdbb2

brightorange = #fe8019

[bar/base]
background = ${colors.background}
border-bottom-size = 0
border-color = #282828
cursor-click = pointer
cursor-scroll = ns-resize
font-0 = "SF Mono:pixelsize=10;2"
font-1 = "FontAwesome5Free:pixelsize=10;1"
font-2 = "FontAwesome5Free:style=Solid:pixelsize=10;1"
font-3 = "Material Icons:size=13;4"
foreground = ${colors.white}
height = 30
line-size = 2
module-margin-right = 3
modules-left = bspwm
padding-left = 0
padding-right = 0
offset-x = 0
offset-y = 0
width = 100%


; Left monitor.
[bar/DP-2]
inherit = bar/base
monitor = DP-2

; Center monitor.
[bar/DP-1]
inherit = bar/base
modules-right = cpu memory filesystem alsa date time
monitor = DP-1
tray-position = right
tray-maxsize = 15
tray-padding = 20


; Right monitor.
[bar/DP-3]
inherit = bar/base
monitor = DP-3

[module/filesystem]
type = internal/fs
internal = 25
mount-0 = /
label-mounted = %{F#83a598}%{F-} %percentage_used%%

[module/date]
type = internal/date
date = "%a %d %B"
format-prefix-foreground = ${colors.brightgreen}
format-prefix = "  "

[module/time]
type = internal/date
interval = 1
date = %H:%M
format-prefix-foreground = ${colors.brightmagenta}
format-prefix = "  "

[module/cpu]
type = internal/cpu
interval = 2
label = " %percentage:1%%"
format-prefix = " "
format-prefix-foreground = ${colors.brightred}

[module/bspwm]
type = internal/bspwm

enable-click = false
enable-scroll = false

label-focused = %name%
label-focused-background = ${colors.background}
label-focused-foreground = ${colors.foreground}
label-focused-underline = ${colors.brightred}
label-focused-padding = 1

label-occupied = %name%
label-occupied-foreground = ${colors.foreground}
label-occupied-padding = 1

label-urgent = %name%!
label-urgent-forground = ${colors.brightred}
label-urgent-padding = 1

label-empty = %name%
label-empty-foreground = ${colors.brightblack}
label-empty-padding = 1

label-dimmed-underline = ${colors.background}
label-dimmed-empty-foreground = ${colors.brightblack}
label-dimmed-foreground = ${colors.foreground}
label-dimmed-occupied-foreground = ${colors.foreground}

[module/memory]
type = internal/memory
interval = 2
format-prefix = " "
format-prefix-foreground = ${colors.brightorange}
format-prefix-background = ${colors.background}
label-background = ${colors.background}
label = "%percentage_used%%"

[module/alsa]
type = internal/alsa
master-mixer = Master
interval = 5
label-volume = %{F#8ec07c}%{F-} %percentage%%
label-volume-foreground = ${colors.white}
label-muted = %{F#8ec07c}%{F-} %{F#fb4934}0%
label-muted-foreground = ${colors.brightred}

[settings]
screenchange-reload = true

[global/wm]
margin-bottom = 0
