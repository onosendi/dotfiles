!
! .Xresources
!

URxvt.iso14755: off
URxvt.iso14755_52: off
URxvt.depth: 32
URxvt.externalBorder: 0
URxvt.internalBorder: 20
URxvt.scrollBar: false
URxvt.cursorBlink: false
URxvt.cursorUnderline: true
URxvt.pointerBlank: false

Xft.dpi: 180
Xft.autohint: 0
Xft.lcdfilter:  lcddefault
Xft.hintstyle:  hintfull
Xft.hinting: 1
Xft.antialias: 1
Xft.rgba: rgb

Xcursor.size: 16


! Fonts ----------------------------------------------------------------------
URxvt.font: xft:Dejavu Sans Mono:size=9
URxvt.allow_bold: false
URxvt.letterSpace: -1


! Plugins --------------------------------------------------------------------

URxvt.perl-ext-common: matcher
URxvt.url-launcher: /usr/bin/chromium
URxvt.matcher.button: 1

! Colors ---------------------------------------------------------------------
*.foreground:   #d0d0d0
*.background:   #1c1c1c
*.cursorColor:  #ffffff

! black
*.color0:       #151515
*.color8:       #272727

! red
*.color1:       #ac4142
*.color9:       #ac4142

! green
*.color2:       #90a959
*.color10:      #90a959

! yellow
*.color3:       #f4bf75
*.color11:      #f4bf75

! blue
*.color4:       #6a9fb5
*.color12:      #6a9fb5

! magenta
*.color5:       #aa759f
*.color13:      #aa759f

! cyan
*.color6:       #75b5aa
*.color14:      #75b5aa

! white
*.color7:       #d0d0d0
*.color15:      #f5f5f5
